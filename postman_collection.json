{
  "info": {
    "name": "Task Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API collection for the Task Microservice"
  },
  "item": [
    {
      "name": "Service Info",
      "request": {
        "method": "GET",
        "url": "http://0.0.0.0:3001/dev/"
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "url": "http://0.0.0.0:3001/dev/tasks",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"My first task\"\n}"
        }
      }
    },
    {
      "name": "Create Task (with status)",
      "request": {
        "method": "POST",
        "url": "http://0.0.0.0:3001/dev/tasks",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Completed task\",\n  \"status\": \"done\"\n}"
        }
      }
    },
    {
      "name": "List All Tasks",
      "request": {
        "method": "GET",
        "url": "http://0.0.0.0:3001/dev/tasks"
      }
    },
    {
      "name": "Get Task by ID",
      "request": {
        "method": "GET",
        "url": "http://0.0.0.0:3001/dev/tasks/{{task_id}}"
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "url": "http://0.0.0.0:3001/dev/tasks/{{task_id}}"
      }
    },
    {
      "name": "Backend - Add Task",
      "request": {
        "method": "POST",
        "url": "http://0.0.0.0:3000/api/add-task",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Task via backend\"\n}"
        }
      }
    },
    {
      "name": "Backend - List Tasks",
      "request": {
        "method": "GET",
        "url": "http://0.0.0.0:3000/api/tasks"
      }
    },
    {
      "name": "Backend - Delete Task",
      "request": {
        "method": "DELETE",
        "url": "http://0.0.0.0:3000/api/task/{{task_id}}"
      }
    }
  ]
}
